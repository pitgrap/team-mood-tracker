{
  "name": "team-mood-tracker",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.30.0",
  "scripts": {
    "lint": "pnpm -r run lint",
    "format": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "devDependencies": {
    "prettier": "^3.8.1"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "pnpm": {
    "overrides": {
      "lodash": ">=4.18.0",
      "@mui/system": "^7.3.10",
      "@mui/utils": "^7.3.10",
      "@mui/material": "^7.3.10",
      "@mui/icons-material": "^7.3.10"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "@mui/system": ">=7",
        "@mui/utils": ">=7",
        "@mui/material": ">=7",
        "@mui/icons-material": ">=7"
      }
    },
    "ignoredBuiltDependencies": [
      "unrs-resolver"
    ]
  }
}

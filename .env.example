# Database
DATABASE_URL=postgresql://test:test@localhost:5433/moodtracker_test

# Auth
JWT_SECRET=your-jwt-secret-here
SURVEY_TOKEN_SECRET=your-survey-token-secret-here
SURVEY_TOKEN_EXPIRY=7d

# Metabase (optional)
METABASE_ENDPOINT=https://your-metabase-instance.com/api/card/1/query
METABASE_API_KEY=your-metabase-api-key

# Admin seed
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=changeme

# Frontend
FRONTEND_URL=http://localhost:5173

# Backend
PORT=3001

# Frontend env (set in frontend/.env)
# VITE_API_URL=http://localhost:3001

# CI/CD
# RENDER_DEPLOY_HOOK=https://api.render.com/deploy/srv-xxx

